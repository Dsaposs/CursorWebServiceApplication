# Copy this file to .env before running docker compose.
# .env is gitignored — never commit it with real values.
#
# Generate a secure JWT key (PowerShell):
#   $bytes = New-Object byte[] 48
#   [Security.Cryptography.RandomNumberGenerator]::Create().GetBytes($bytes)
#   [Convert]::ToBase64String($bytes)
#
# Or (bash / WSL):
#   openssl rand -base64 48

TTRPG_JWT_KEY=replace-with-a-random-base64-string-at-least-48-bytes-long

# Must be at least 12 chars, contain uppercase + digit.
TTRPG_SEED_ADMIN_PASSWORD=ChangeThisAdminPassword1!
