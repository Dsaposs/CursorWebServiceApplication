# ── API (ASP.NET Core) ────────────────────────────────────────────────────
# PostgreSQL connection (override the default SQLite dev database)
DATABASE_URL=Host=localhost;Port=5432;Database=ttrpg;Username=ttrpg;Password=ttrpg_dev

# Redis connection string for SignalR backplane (optional — in-memory if omitted)
ConnectionStrings__Redis=localhost:6379

# JWT signing key — MUST be changed in production (min 32 chars)
Jwt__Key=TtrpgApi-Dev-Signing-Key-Min-32-Chars-Long!
Jwt__Issuer=TtrpgApi
Jwt__Audience=TtrpgApi

# Seed admin password — change in production
Seed__AdminPassword=Password1

# ── UI (Nuxt BFF) ─────────────────────────────────────────────────────────
# URL of the backend API reachable from the Nuxt server process
NUXT_API_BASE_URL=http://localhost:5294

# URL of the LLM oracle service (leave blank to disable oracle feature)
NUXT_LLM_BASE_URL=http://localhost:8000

# ── LLM (FastAPI) ─────────────────────────────────────────────────────────
OLLAMA_URL=http://localhost:11434
EMBED_MODEL=nomic-embed-text
LLM_MODEL=mistral:7b-instruct
